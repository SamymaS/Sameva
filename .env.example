# ---------------------------------------------------------------------------
# Configuration de l'application Flutter.
# Copier ce fichier en .env a la racine du projet, puis renseigner les valeurs.
#   cp .env.example .env
# Ce fichier est charge au demarrage (main.dart) et embarque comme asset.
# ---------------------------------------------------------------------------

# Supabase : Dashboard > Settings > API
# La cle anon est PUBLIQUE par conception : elle est protegee par la RLS.
# Ne JAMAIS placer ici la cle service_role, ni une cle Anthropic ou Stripe :
# ces secrets vivent cote serveur (voir supabase/.env.local.example).
SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Edge Functions (optionnel).
# Si VALIDATION_AI_URL est vide ou absente, l'application bascule sur
# MockValidationAIService : elle fonctionne sans backend IA et sans cout.
# C'est le mode utilise par la chaine d'integration continue.
VALIDATION_AI_URL=
SUGGEST_QUESTS_URL=

# Valeurs completes une fois les fonctions deployees :
# VALIDATION_AI_URL=https://VOTRE_PROJECT_REF.supabase.co/functions/v1/analyze-quest-proof
# SUGGEST_QUESTS_URL=https://VOTRE_PROJECT_REF.supabase.co/functions/v1/suggest-quests
