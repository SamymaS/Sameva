# ---------------------------------------------------------------------------
# Secrets serveur des Edge Functions, developpement LOCAL uniquement.
# Copier en supabase/.env.local, puis :
#   supabase functions serve analyze-quest-proof
#
# En production, ces valeurs ne sont PAS dans un fichier : elles sont poussees
# dans les secrets Supabase et ne sont lisibles que par les fonctions :
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# SUPABASE_URL, SUPABASE_ANON_KEY et SUPABASE_SERVICE_ROLE_KEY sont injectees
# automatiquement par la plateforme : inutile de les declarer ici.
# ---------------------------------------------------------------------------

# Validation de preuve et generation de quetes (Claude Haiku Vision)
# Console Anthropic : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Abonnement premium (Stripe, mode test suffisant)
# Dashboard Stripe > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...
# Dashboard Stripe > Developers > Webhooks (secret de signature de l'endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# Identifiant du tarif de l'abonnement premium (Dashboard Stripe > Products)
STRIPE_PRICE_ID=price_...
